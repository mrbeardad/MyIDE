{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "shell_integration": true,
  "enable_cursor_positioning": true,
  "pwd": "osc99",
  "console_title_template": "{{ .Folder }}",
  "final_space": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "diamond",
          "leading_diamond": "<darkGray,transparent>Ôò¡ÔöÇ</>¯éÂ",
          "trailing_diamond": "¯é░",
          "foreground": "white",
          "background": "cyan",
          "template": " {{ .Icon }} ",
          "cache": {
            "duration": "infinite",
            "strategy": "session"
          }
        },
        {
          "type": "root",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "foreground": "lightYellow",
          "background": "lightRed",
          "template": " ¾░Æâ ",
          "cache": {
            "duration": "infinite",
            "strategy": "session"
          }
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "foreground": "white",
          "background": "blue",
          "template": " {{ path .Path .Location }} ",
          "options": {
            "style": "full",
            "home_icon": "¯¼å ",
            "folder_icon": "´ü╝ ",
            "folder_separator_icon": "¯é▒ "
          }
        },
        {
          "type": "rust",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "foreground": "#193549",
          "background": "#99908a",
          "template": " ¯×¿ {{ .Full }} "
        },
        {
          "type": "dotnet",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "foreground": "#000000",
          "background": "#00ffff",
          "template": " ¯Ø┐ {{ .Full }} "
        },
        {
          "type": "go",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "foreground": "#ffffff",
          "background": "#7FD5EA",
          "template": " ¯ÿº {{ .Full }} "
        },
        {
          "type": "node",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "foreground": "#ffffff",
          "background": "#6CA35E",
          "template": " ¯£ÿ {{ .Full }} "
        },
        {
          "type": "python",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "foreground": "#100e23",
          "background": "#906cff",
          "template": " ¯êÁ {{ .Full }} "
        },
        {
          "type": "lua",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "foreground": "#ffffff",
          "background": "#000081",
          "template": " ¯ÿá {{ .Full }} "
        },
        {
          "type": "text",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "foreground": "white",
          "background": "magenta",
          "templates": [
            "{{ if .Env.HTTP_PROXY }} ¯¡É {{ .Env.HTTP_PROXY }} {{ end }}",
            "{{ if .Env.HTTPS_PROXY }} ¯¡É {{ .Env.HTTPS_PROXY }} {{ end }}",
            "{{ if .Env.ALL_PROXY }} ¯¡É {{ .Env.ALL_PROXY }} {{ end }}"
          ],
          "templates_logic": "first_match"
        },
        {
          "type": "time",
          "style": "powerline",
          "powerline_symbol": "¯é░",
          "foreground": "white",
          "background": "cyan",
          "template": " ¯Öü {{ .CurrentDate | date .Format }}",
          "options": {
            "time_format": "15:04:05"
          }
        },
        {
          "type": "executiontime",
          "style": "diamond",
          "foreground": "lightWhite",
          "background": "darkGray",
          "leading_diamond": "<transparent,background>¯é░</>",
          "trailing_diamond": "¯é┤",
          "template": " ´Çù  {{ .FormattedMs }}",
          "options": {
            "style": "austin",
            "threshold": 0
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "status",
          "style": "plain",
          "templates": [
            "<darkGray>Ôò░ÔöÇ</>",
            " {{ if ne .Code 0 }}<lightRed>ÔØ»</><red>ÔØ»</>{{ else }}<lightBlue>ÔØ»</><lightCyan>ÔØ»</>{{ end }}"
          ],
          "options": {
            "always_enabled": true
          }
        }
      ],
      "newline": true
    }
  ],
  "transient_prompt": {
    "foreground_templates": [
      "{{ if ne .Code 0 }}lightRed{{ else }}lightGreen{{ end }}"
    ],
    "template": "¯èà "
  }
}

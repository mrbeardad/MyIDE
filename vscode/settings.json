{
  "settingsSync.ignoredSettings": ["workbench.colorTheme", "editor.minimap.scale"],
  "settingsSync.ignoredExtensions": ["johnstoncode.svn-scm", "vue.volar"],

  "editor.autoIndentOnPaste": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.guides.bracketPairs": "active",
  "editor.hover.delay": 100,
  "editor.hover.hidingDelay": 100,
  "editor.linkedEditing": true,
  "editor.renderControlCharacters": true,
  "editor.renderWhitespace": "all",
  "editor.rulers": [100],
  "editor.smoothScrolling": true,
  "editor.tabCompletion": "on",
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "string",
        "settings": {
          "fontStyle": "italic"
        }
      }
    ]
  },
  "editor.unfoldOnClickAfterEndOfLine": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorSurroundingLines": 5,
  "editor.fontFamily": "SauceCodePro Nerd Font",
  "editor.formatOnSave": true,
  "editor.minimap.autohide": "mouseover",
  "editor.acceptSuggestionOnEnter": "off",
  "editor.quickSuggestions": {
    "comments": "on",
    "strings": "on"
  },
  "editor.suggest.preview": true,
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.suggestSelection": "recentlyUsed",

  "workbench.list.smoothScrolling": true,
  "workbench.productIconTheme": "fluent-icons",
  "workbench.colorCustomizations": {
    "[Noctis Sereno]": {
      "statusBar.foreground": "#b9d3d6",
      "statusBar.background": "#005f5f",
      "statusBar.debuggingForeground": "#a9c1c4",
      "statusBar.debuggingBackground": "#396336",
      "statusBarItem.hoverBackground": "#007d7d",
      "editor.findMatchBackground": "#40bf6acc",
      "editor.findMatchHighlightBackground": "#0e6571cc",
      "editorWidget.background": "#083d44cc"
    },
    "[Noctis Hibernus]": {
      "editorWidget.background": "#e0eff1bb"
    }
  },
  "workbench.iconTheme": "material-icon-theme",
  "workbench.preferredDarkColorTheme": "Noctis Sereno",
  "workbench.preferredHighContrastColorTheme": "Noctis Sereno",
  "workbench.preferredHighContrastLightColorTheme": "Noctis Hibernus",
  "workbench.preferredLightColorTheme": "Noctis Hibernus",
  "workbench.tree.expandMode": "doubleClick",
  "workbench.view.alwaysShowHeaderActions": true,
  "workbench.editor.defaultBinaryEditor": "hexEditor.hexedit",
  "workbench.editor.pinnedTabsOnSeparateRow": true,
  "workbench.editor.revealIfOpen": true,
  "workbench.settings.alwaysShowAdvancedSettings": true,

  "window.autoDetectColorScheme": true,

  "explorer.confirmDelete": false,
  "outline.collapseItems": "alwaysCollapse",

  "search.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "**/third_party": true,
    "**/vendor": true,
    "**/venv": true,
    "**/build": true,
    "**/dist": true,
    "**/out": true,
    "**/output": true,
    "**/release": true,
    "**/releases": true,
    "**/static": true,
    "**/.cache": true,
    "**/target": true,
    "**/CHANGELOG": true,
    "**/CHANGELOG.*": true,
    "**/*.min.*": true,
    "**/*.map": true,
    "**/*.{asar,3ds,3g2,3gp,7z,a,aac,adp,ai,aif,aiff,alz,ape,apk,ar,arj,asf,au,avi,bak,baml,bh,bin,bk,bmp,btif,bz2,bzip2,cab,caf,cgm,class,cmx,cpio,cr2,csv,cur,dat,dcm,deb,dex,djvu,dll,dmg,dng,doc,docm,docx,dot,dotm,dra,DS_Store,dsk,dts,dtshd,dvb,dwg,dxf,ecelp4800,ecelp7470,ecelp9600,egg,eol,eot,epub,exe,f4v,fbs,fh,fla,flac,fli,flv,fpx,fst,fvt,g3,gif,graffle,gz,gzip,h261,h263,h264,icns,ico,ief,img,ipa,iso,jar,jpeg,jpg,jpgv,jpm,jxr,key,ktx,lha,lib,lvp,lz,lzh,lzma,lzo,m3u,m4a,m4v,mar,mdi,mht,mid,midi,mj2,mka,mkv,mmr,mng,mobi,mov,movie,mp3,mp4,mp4a,mpeg,mpg,mpga,mxu,nef,npx,numbers,o,oga,ogg,ogv,otf,pages,pbm,pcx,pdb,pdf,pea,pgm,pic,png,pnm,pot,potm,potx,ppa,ppam,ppm,pps,ppsm,ppsx,ppt,pptm,pptx,psd,pya,pyc,pyo,pyv,qt,rar,ras,raw,resources,rgb,rip,rlc,rmf,rmvb,rtf,rz,s3m,s7z,scpt,sgi,shar,sil,sketch,slk,smv,so,sub,swf,tar,tbz,tbz2,tga,tgz,thmx,tif,tiff,tlz,ttc,ttf,txz,udf,uvh,uvi,uvm,uvp,uvs,uvu,viv,vob,war,wav,wax,wbmp,wdp,weba,webm,webp,whl,wim,wm,wma,wmv,wmx,woff,woff2,wvx,xbm,xif,xla,xlam,xls,xlsb,xlsm,xlsx,xlt,xltm,xltx,xm,xmind,xpi,xpm,xwd,xz,z,zip,zipx}": true
  },
  "search.showLineNumbers": true,
  "search.smartCase": true,

  "debug.toolBarLocation": "commandCenter",

  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.mouseWheelScrollSensitivity": 0.5,
  "terminal.integrated.sendKeybindingsToShell": true,
  "terminal.integrated.suggest.enabled": false,

  "problems.showCurrentInStatus": true,

  "security.workspace.trust.enabled": false,

  "git.autofetch": true,
  "git.confirmSync": false,
  "gitlens.statusBar.enabled": false,
  "gitlens.graph.layout": "editor",
  "gitlens.graph.minimap.additionalTypes": ["stashes", "tags", "localBranches", "remoteBranches"],
  "gitlens.launchpad.indicator.enabled": false,
  "gitlens.views.scm.grouped.views": {
    "branches": true,
    "remotes": true,
    "stashes": true,
    "tags": true,
    "fileHistory": true,
    "repositories": true,
    "searchAndCompare": true,
    "launchpad": true
  },
  "gitlens.views.scm.grouped.hiddenViews": {
    "commits": true,
    "worktrees": true,
    "branches": false,
    "remotes": false,
    "stashes": false,
    "tags": false,
    "contributors": true,
    "repositories": true,
    "fileHistory": false,
    "launchpad": true,
    "searchAndCompare": true
  },
  "gitlens.views.branches.showStashes": true,
  "gitlens.ai.enabled": false,
  "gitlens.blame.ignoreWhitespace": true,

  "C_Cpp.intelliSenseEngine": "disabled",
  "clangd.path": "c:\\Users\\beardad\\AppData\\Roaming\\Code\\User\\globalStorage\\llvm-vs-code-extensions.vscode-clangd\\install\\22.1.0\\clangd_22.1.0\\bin\\clangd.exe",
  "cmake.copyCompileCommands": "${workspaceFolder}/compile_commands.json",
  "cmake.options.statusBarVisibility": "icon",
  "cmake.format.allowOptionalArgumentIndentation": true,

  "js/ts.inlayHints.enumMemberValues.enabled": true,
  "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
  "js/ts.inlayHints.parameterNames.enabled": "literals",
  "js/ts.inlayHints.parameterTypes.enabled": true,
  "js/ts.inlayHints.propertyDeclarationTypes.enabled": true,
  "js/ts.inlayHints.variableTypes.enabled": true,

  "python.analysis.autoImportCompletions": true,
  "python.analysis.completeFunctionParens": true,
  "python.analysis.inlayHints.functionReturnTypes": true,
  "python.analysis.inlayHints.pytestParameters": true,
  "python.analysis.inlayHints.variableTypes": true,
  "python.useEnvironmentsExtension": false,

  "[markdown]": {
    "outline.collapseItems": "alwaysExpand"
  },
  "markdown.copyFiles.destination": {
    "**/*.md": "${documentWorkspaceFolder}/images/${fileName}"
  },

  "evenBetterToml.formatter.columnWidth": 100,

  "protobuf.formatOnSave": true,
  "protobuf.autoDetection.enabled": false,

  "todo-tree.filtering.useBuiltInExcludes": "file and search excludes",
  "todo-tree.tree.hideTreeWhenEmpty": true,
  "todo-tree.tree.flat": true,
  "todo-tree.tree.tagsOnly": true,
  "todo-tree.highlights.customHighlight": {
    "BUG": {
      "icon": "bug",
      "foreground": "#ddd",
      "background": "#db4b4b",
      "iconColour": "#db4b4b"
    },
    "FIXME": {
      "icon": "tools",
      "foreground": "#1a1b26",
      "background": "#bb9af7",
      "iconColour": "#bb9af7"
    },
    "TODO": {
      "icon": "check-circle",
      "foreground": "#1a1b26",
      "background": "#0db9d7",
      "iconColour": "#0db9d7"
    },
    "HACK": {
      "icon": "flame",
      "foreground": "#1a1b26",
      "background": "#e0af68",
      "iconColour": "#e0af68"
    },
    "XXX": {
      "icon": "alert",
      "foreground": "#1a1b26",
      "background": "#e0af68",
      "iconColour": "#e0af68"
    }
  },

  "chat.viewSessions.orientation": "stacked",
